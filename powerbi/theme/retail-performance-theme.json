{
  "name": "Retail Performance Analytics",
  "dataColors": ["#1267E8", "#2D7FF0", "#0E4FAF", "#169B62", "#E59F24", "#7B879D", "#F08FA0"],
  "background": "#F7F9FC",
  "foreground": "#121A30",
  "tableAccent": "#1267E8",
  "good": "#169B62",
  "neutral": "#7B879D",
  "bad": "#C84B5A",
  "maximum": "#1267E8",
  "center": "#D9E8FC",
  "minimum": "#EFF5FD",
  "textClasses": {
    "title": {"fontFace": "Segoe UI Semibold", "fontSize": 18, "color": "#121A30"},
    "header": {"fontFace": "Segoe UI Semibold", "fontSize": 12, "color": "#121A30"},
    "label": {"fontFace": "Segoe UI", "fontSize": 10, "color": "#40506A"},
    "callout": {"fontFace": "Segoe UI Semibold", "fontSize": 28, "color": "#121A30"}
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{"color": {"solid": {"color": "#FFFFFF"}}, "transparency": 0}],
